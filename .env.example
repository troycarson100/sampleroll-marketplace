# Postgres: use the SAME database as Sample Dig at launch (shared `public.users`).
# Local dev: copy to .env.local. Paste URI from Supabase → Connect.
# Direct db.*.supabase.co:5432 is often IPv6-only — if Prisma shows P1001, use Session pooler from Connect (IPv4).
# Add ?sslmode=require; URL-encode special chars in the password (! → %21).
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"

# Serverless deploys only: Supabase transaction pooler (6543) + Prisma often needs:
#   ?pgbouncer=true&connection_limit=1&sslmode=require
# See docs/DATABASE_URL.md

# NextAuth — REQUIRED (non-empty). If missing, /api/auth/session returns 500 and the app breaks.
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET="paste-a-long-random-string-here"
AUTH_SECRET="same-value-as-NEXTAUTH_SECRET-or-omit-if-you-only-use-NEXTAUTH_SECRET"
NEXTAUTH_URL="http://localhost:3001"

# Public site URL (Stripe redirects & Connect return URLs — match dev server port)
NEXT_PUBLIC_APP_URL="http://localhost:3001"

# Supabase — public key (Data API / Realtime / optional SSR helpers). Use ONE of:
# New dashboard: publishable key (sb_publishable_…)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=
# Legacy JWT anon key (still supported)
NEXT_PUBLIC_SUPABASE_ANON_KEY="anon-key"
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
# Server-only: storage + webhooks (never expose to the client)
SUPABASE_SERVICE_ROLE_KEY="service-role-key"

# Stripe (Test keys from Dashboard → Developers → API keys)
STRIPE_SECRET_KEY=
# Webhook signing secret (Dashboard webhook destination, or `whsec_...` from `npm run stripe:listen`)
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Optional: ISO country for new Connect Express accounts (default US)
# STRIPE_CONNECT_ACCOUNT_COUNTRY=US

# Platform admin — comma-separated emails with full access (contracts + supervisors)
PLATFORM_OWNER_EMAILS="troy@sampleroll.com"

# Optional: Resend for contract invitation emails (otherwise copy link from UI)
# RESEND_API_KEY=
# RESEND_FROM_EMAIL="SampleRoll <onboarding@yourdomain.com>"
