{
  "name": "sampleroll-marketplace",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3001",
    "dev:clean": "rm -rf .next node_modules/.cache && next dev -p 3001",
    "dev:3001": "next dev -p 3001",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "postinstall": "prisma generate",
    "db:ping": "printf 'SELECT 1;\\n' | dotenv -e .env.local -- npx prisma db execute --stdin",
    "db:run-sql": "node scripts/run-sql-file.mjs",
    "db:probe-pooler": "node scripts/supabase-pooler-probe.mjs",
    "db:pooler-host": "node scripts/print-supabase-pooler-host.mjs",
    "stripe:listen": "stripe listen --forward-to localhost:3001/api/stripe/marketplace-webhook"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@prisma/client": "5.22.0",
    "@stripe/stripe-js": "^8.11.0",
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.99.3",
    "@types/bcryptjs": "^2.4.6",
    "bcryptjs": "^3.0.3",
    "client-only": "^0.0.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.577.0",
    "next": "14.2.35",
    "next-auth": "^5.0.0-beta.25",
    "prisma": "5.22.0",
    "react": "^18",
    "react-dom": "^18",
    "react-dropzone": "^15.0.0",
    "server-only": "^0.0.1",
    "stripe": "^20.4.1",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "eslint": "^8",
    "eslint-config-next": "14.2.35",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "typescript": "^5"
  }
}
