// Shared with Sample Dig: `users` table + marketplace tables (NextAuth session user.id = users.id).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                           String    @id @default(cuid())
  email                        String    @unique
  passwordHash                 String    @map("password_hash")
  name                         String?
  stripeCustomerId             String?   @map("stripe_customer_id")
  subscriptionStatus           String?   @map("subscription_status")
  subscriptionCurrentPeriodEnd DateTime? @map("subscription_current_period_end")
  createdAt                    DateTime  @default(now()) @map("created_at")
  emailVerified                DateTime? @map("email_verified")
  emailVerificationToken       String?   @unique @map("email_verification_token")
  emailVerificationExpires     DateTime? @map("email_verification_expires")
  passwordResetToken           String?   @unique @map("password_reset_token")
  passwordResetExpires         DateTime? @map("password_reset_expires")

  profileMarketplace ProfileMarketplace?
  samplePacks        SamplePack[]        @relation("CreatorPacks")
  purchases          UserPurchase[]
  creatorEarnings    CreatorEarning[]
  platformStaff      PlatformStaff?
  contractsAsCreator CreatorContract[]   @relation("ContractCreator")
  contractsCreated   CreatorContract[]   @relation("ContractCreatedBy")

  @@map("users")
}

model PlatformStaff {
  id        String   @id @default(cuid())
  userId    String   @unique @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("platform_staff")
}

enum CreatorContractStatus {
  DRAFT
  PENDING_REVIEW
  ACTIVE
  DECLINED
  VOID

  @@map("creator_contract_status")
}

model CreatorContract {
  id                  String                @id @default(uuid()) @db.Uuid
  creatorUserId       String                @map("creator_user_id")
  inviteEmailNorm     String                @map("invite_email_norm")
  splitPercentage     Int                   @map("split_percentage")
  title               String                @default("Revenue share agreement")
  notes               String                @default("")
  legalObjectPath     String?               @map("legal_object_path")
  legalFilename       String?               @map("legal_filename")
  status              CreatorContractStatus @default(DRAFT)
  acceptanceToken     String                @unique @map("acceptance_token")
  createdByUserId     String                @map("created_by_user_id")
  sentAt              DateTime?             @map("sent_at")
  acceptedAt          DateTime?             @map("accepted_at")
  declinedAt          DateTime?             @map("declined_at")
  createdAt           DateTime              @default(now()) @map("created_at")
  updatedAt           DateTime              @updatedAt @map("updated_at")

  creator   User @relation("ContractCreator", fields: [creatorUserId], references: [id], onDelete: Cascade)
  createdBy User @relation("ContractCreatedBy", fields: [createdByUserId], references: [id], onDelete: Restrict)

  @@index([creatorUserId])
  @@index([inviteEmailNorm])
  @@map("creator_contracts")
}

model ProfileMarketplace {
  id                              String   @id
  isCreator                       Boolean  @default(false) @map("is_creator")
  creatorDisplayName              String?  @map("creator_display_name")
  creatorBio                      String?  @map("creator_bio")
  creatorAvatarUrl                String?  @map("creator_avatar_url")
  customSplitPercentage           Int?     @map("custom_split_percentage")
  paypalEmail                     String?  @map("paypal_email")
  stripeConnectAccountId          String?  @map("stripe_connect_account_id")
  stripeConnectChargesEnabled     Boolean  @default(false) @map("stripe_connect_charges_enabled")
  stripeConnectPayoutsEnabled     Boolean  @default(false) @map("stripe_connect_payouts_enabled")
  stripeConnectDetailsSubmitted   Boolean  @default(false) @map("stripe_connect_details_submitted")
  createdAt                       DateTime @default(now()) @map("created_at")
  updatedAt                       DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [id], references: [id], onDelete: Cascade)

  @@map("profiles_marketplace")
}

model SamplePack {
  id            String   @id @default(uuid()) @db.Uuid
  creatorId     String   @map("creator_id")
  title         String
  description   String   @default("")
  genre         String
  tags          String[] @default([])
  coverArtUrl   String?  @map("cover_art_url")
  priceCents    Int      @default(1499) @map("price_cents")
  stripePriceId String?  @map("stripe_price_id")
  sampleCount   Int      @default(0) @map("sample_count")
  totalSales    Int      @default(0) @map("total_sales")
  isPublished   Boolean  @default(false) @map("is_published")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  creator         User               @relation("CreatorPacks", fields: [creatorId], references: [id], onDelete: Cascade)
  samples         IndividualSample[]
  purchases       UserPurchase[]
  creatorEarnings CreatorEarning[]

  @@map("sample_packs")
}

model IndividualSample {
  id               String   @id @default(uuid()) @db.Uuid
  packId           String   @map("pack_id") @db.Uuid
  filename         String
  originalFilename String   @map("original_filename")
  fileUrl          String   @map("file_url")
  previewUrl       String?  @map("preview_url")
  durationSeconds  Float?   @map("duration_seconds")
  bpm              Int?
  musicalKey       String?  @map("musical_key")
  instrumentTags   String[] @default([]) @map("instrument_tags")
  genreTags        String[] @default([]) @map("genre_tags")
  sortOrder        Int      @default(0) @map("sort_order")
  createdAt        DateTime @default(now()) @map("created_at")

  pack SamplePack @relation(fields: [packId], references: [id], onDelete: Cascade)

  @@map("individual_samples")
}

model UserPurchase {
  id                    String   @id @default(uuid()) @db.Uuid
  userId                String   @map("user_id")
  packId                String   @map("pack_id") @db.Uuid
  stripePaymentIntentId String   @map("stripe_payment_intent_id")
  amountCents           Int      @map("amount_cents")
  createdAt             DateTime @default(now()) @map("created_at")

  user     User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  pack     SamplePack       @relation(fields: [packId], references: [id], onDelete: Restrict)
  earnings CreatorEarning[]

  @@unique([userId, packId])
  @@map("user_purchases")
}

model CreatorEarning {
  id                  String    @id @default(uuid()) @db.Uuid
  creatorId           String    @map("creator_id")
  packId              String    @map("pack_id") @db.Uuid
  purchaseId          String    @map("purchase_id") @db.Uuid
  saleAmountCents     Int       @map("sale_amount_cents")
  creatorShareCents   Int       @map("creator_share_cents")
  platformShareCents  Int       @map("platform_share_cents")
  splitPercentage     Int       @map("split_percentage")
  isPaidOut           Boolean   @default(false) @map("is_paid_out")
  paidOutAt           DateTime? @map("paid_out_at")
  createdAt           DateTime  @default(now()) @map("created_at")

  creator  User         @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  pack     SamplePack   @relation(fields: [packId], references: [id], onDelete: Restrict)
  purchase UserPurchase @relation(fields: [purchaseId], references: [id], onDelete: Restrict)

  @@map("creator_earnings")
}
